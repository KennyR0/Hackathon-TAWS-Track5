# NexoMercado AI - entorno local

# ---- LLM ----
OPENAI_API_KEY=replace_with_a_real_key
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
LLM_PROVIDER=fixture

# ---- Runtime base ----
REPOSITORY_BACKEND=fixture
MARKET_DATA_MODE=fixture
FIXTURE_BUNDLE_PATH=data/fixtures/v1/phase0_bundle.json
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ---- Supabase durable overlay ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# ---- Market data providers ----
GDELT_API_KEY=
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_TIMEOUT_SECONDS=6
GDELT_MAX_ATTEMPTS=2
GDELT_CACHE_TTL_SECONDS=900
SEC_USER_AGENT=NexoMercadoAI/1.0
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
COINGECKO_API_KEY=
FRED_API_KEY=

# Frontend public configuration. Keep privileged provider keys in backend env only.
VITE_API_BASE_URL=/api

# ---- Variables opcionales no consumidas por el backend actual ----
# SUPABASE_ANON_KEY=
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_URL=
# SUPABASE_SECRET_KEY=
