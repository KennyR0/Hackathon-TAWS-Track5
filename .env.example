# NexoMercado AI - complete local environment example
# Copy to .env for repo-root scripts that accept --env-file .env.
#
# This file intentionally defaults to a safe offline/demo profile:
# - fixture LLM
# - fixture repository
# - fixture market data
# - auth disabled
# - no external secrets required
#
# For app-specific local files you can also copy:
# - backend/.env.example  -> backend/.env.local
# - frontend/.env.example -> frontend/.env.local

# =============================================================================
# Backend runtime
# =============================================================================

LLM_PROVIDER=fixture
REPOSITORY_BACKEND=fixture
MARKET_DATA_MODE=fixture
MARKET_REQUEST_BUDGET=32
MARKET_BATCH_SIZE=10
MARKET_REFRESH_SECONDS=900
# Optional per-provider overrides. Valid periods: minute, hour, day, month.
# Twelve Data Basic currently grants 800 daily credits and batch requests
# consume one credit per symbol; keep 40 credits as a configurable reserve.
MARKET_PROVIDER_BUDGETS={"twelve_data":{"period":"day","maxRequests":800,"safetyReserve":40}}
FIXTURE_BUNDLE_PATH=data/fixtures/v1/phase0_bundle.json

# Local frontend origins. For Vercel, add the exact frontend origin without a
# trailing slash, for example:
# BACKEND_CORS_ORIGINS=https://<vercel-app>.vercel.app,http://localhost:5173,http://127.0.0.1:5173
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# =============================================================================
# Backend OpenAI agents
# =============================================================================

# Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
# Valid OPENAI_REASONING_EFFORT values: minimal, low, medium, high, xhigh

# =============================================================================
# Backend Supabase persistence and auth
# =============================================================================

# Required only when REPOSITORY_BACKEND=supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Keep false for public demo/fallback mode.
AUTH_ENABLED=false
SUPABASE_JWT_SECRET=

# Optional public Supabase values. These are useful for frontend auth when
# VITE_AUTH_ENABLED=true; they are not privileged.
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# =============================================================================
# Backend live/hybrid market data providers
# =============================================================================

# Used only when MARKET_DATA_MODE=live or MARKET_DATA_MODE=hybrid.
GDELT_API_KEY=
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_TIMEOUT_SECONDS=6
GDELT_MAX_ATTEMPTS=2
GDELT_CACHE_TTL_SECONDS=900
SEC_USER_AGENT=NexoMercadoAI/1.0
FINNHUB_API_KEY=
FINNHUB_API_KEY_2=
TWELVE_DATA_API_KEY=
TWELVE_DATA_API_KEY_2=
COINGECKO_API_KEY=
COINGECKO_API_KEY_2=
FRED_API_KEY=
FRED_API_KEY_2=
# Optional free EIA key used only when FRED cannot provide WTI.
EIA_API_KEY=
# YH Finance via RapidAPI. Replace only the key placeholder.
RAPIDAPI_KEY=tu_clave_de_rapidapi
YAHOO_FINANCE_API_HOST=yahoo-finance15.p.rapidapi.com
YAHOO_FINANCE_BASE_URL=https://yahoo-finance15.p.rapidapi.com
YAHOO_FINANCE_HISTORY_PATH=/api/v2/markets/stock/history

# Optional. Used by backend/scripts/check_live_demo_flow.py when auth is enabled.
DEMO_ACCESS_TOKEN=

# =============================================================================
# Frontend public variables
# =============================================================================

# Local fallback through Vite proxy.
VITE_API_BASE_URL=/api

# Vercel/Render deployment example:
# VITE_API_BASE_URL=https://<render-service>.onrender.com/api

# Backward-compatible alias accepted by the frontend.
VITE_API_URL=

# Keep false for demo/fallback mode. If true, configure Supabase Auth and
# matching backend AUTH_ENABLED/SUPABASE_JWT_SECRET.
VITE_AUTH_ENABLED=false
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# Optional external-platform notes
# =============================================================================

# Render backend:
# - Set backend secrets in Render, not in Vercel.
# - Required for real OpenAI mode: OPENAI_API_KEY, LLM_PROVIDER=openai.
# - Required for Supabase persistence: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
#   REPOSITORY_BACKEND=supabase.
# - Required for deployed frontend calls: BACKEND_CORS_ORIGINS must include
#   the exact Vercel origin.
#
# Vercel frontend:
# - Set only VITE_* values.
# - Do not set OPENAI_API_KEY, SUPABASE_SERVICE_ROLE_KEY, FINNHUB_API_KEY,
#   TWELVE_DATA_API_KEY, FRED_API_KEY, or other backend secrets in Vercel.
