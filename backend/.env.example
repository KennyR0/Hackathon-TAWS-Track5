# NexoMercado AI backend local configuration
# Copy this file to backend/.env or export these variables in your shell.

# Offline demo defaults. These do not require external credentials.
LLM_PROVIDER=fixture
REPOSITORY_BACKEND=fixture
MARKET_DATA_MODE=fixture
FIXTURE_BUNDLE_PATH=data/fixtures/v1/phase0_bundle.json
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# OpenAI-backed agents. Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=replace_with_a_real_key
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium

# Supabase persistence. Required only when REPOSITORY_BACKEND=supabase.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Optional live market/news providers. Used only by live or hybrid market modes.
GDELT_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
COINGECKO_API_KEY=
FRED_API_KEY=
