# NexoMercado AI - backend environment example
# Copy to backend/.env.local for local backend runs, or configure the same
# variables in Render for the deployed backend.
#
# Safe fallback profile:
# - no external secrets required
# - uses fixture LLM responses
# - uses fixture repository data
# - uses fixture market data
# - disables Supabase Auth

# ---- Runtime fallbacks ----
LLM_PROVIDER=fixture
REPOSITORY_BACKEND=fixture
MARKET_DATA_MODE=fixture
FIXTURE_BUNDLE_PATH=data/fixtures/v1/phase0_bundle.json

# Explicit browser origins allowed to call the API.
# Local fallback:
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Deploy fallback example:
# BACKEND_CORS_ORIGINS=https://<vercel-app>.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# ---- OpenAI agents ----
# Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
# Valid OPENAI_REASONING_EFFORT values: minimal, low, medium, high, xhigh

# ---- Supabase persistence ----
# Required only when REPOSITORY_BACKEND=supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase Auth ----
# Keep false for public demo/fallback mode. When true, API routes require
# Authorization: Bearer <Supabase access token>.
AUTH_ENABLED=false
SUPABASE_JWT_SECRET=

# ---- Live/hybrid market data providers ----
# Used only when MARKET_DATA_MODE=live or MARKET_DATA_MODE=hybrid.
# Empty values degrade to fixture/fallback responses where provider code allows it.
GDELT_API_KEY=
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_TIMEOUT_SECONDS=6
GDELT_MAX_ATTEMPTS=2
GDELT_CACHE_TTL_SECONDS=900
SEC_USER_AGENT=NexoMercadoAI/1.0
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
COINGECKO_API_KEY=
FRED_API_KEY=

# ---- Demo smoke script ----
# Optional. Used by backend/scripts/check_live_demo_flow.py when AUTH_ENABLED=true.
DEMO_ACCESS_TOKEN=
