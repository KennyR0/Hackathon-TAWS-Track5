{
  "manifestVersion": 1,
  "sourceOfTruth": "Pydantic -> OpenAPI",
  "wireConvention": "camelCase",
  "pathSyntax": "Schema.field; [] denotes each array item",
  "semantics": {
    "requiredPaths": "Every path must exist in the referenced OpenAPI schema and be projectable from at least one valid fixture.",
    "nullablePaths": "These paths remain part of the contract but their runtime value may be null."
  },
  "canonicalNames": {
    "Article.url": "Canonical URL of the article",
    "Article.dataMode": "Effective data mode",
    "Article.provider": "Ingestion provider",
    "Article.dataAsOf": "Date or instant represented by the data",
    "Article.warnings": "Freshness or provenance warnings",
    "Event.eventAt": "Canonical event timestamp",
    "Signal.evidenceIds": "Supporting evidence identifiers",
    "Signal.counterEvidenceIds": "Contradictory evidence identifiers",
    "Signal.suggestedResearchActions": "Suggested research actions",
    "ReviewRequest.status": "Requested review status"
  },
  "forbiddenAliases": [
    {
      "schema": "Signal",
      "alias": "supportingEvidenceIds",
      "use": "evidenceIds"
    },
    {
      "schema": "Signal",
      "alias": "researchActions",
      "use": "suggestedResearchActions"
    },
    {
      "schema": "ReviewRequest",
      "alias": "newStatus",
      "use": "status"
    },
    {
      "schema": "Event",
      "alias": "occurredAt",
      "use": "eventAt"
    },
    {
      "schema": "Article",
      "alias": "sourceUrl",
      "use": "url"
    },
    {
      "schema": "Article",
      "alias": "mode",
      "use": "dataMode"
    },
    {
      "schema": "Article",
      "alias": "freshnessWarnings",
      "use": "warnings"
    }
  ],
