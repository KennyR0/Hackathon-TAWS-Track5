# NexoMercado AI - frontend public environment example
# Copy to frontend/.env.local for local Vite runs, or configure the same
# variables in Vercel for the deployed frontend.
#
# Only VITE_* values are exposed to the browser. Do not put backend secrets here.

# ---- API base URL ----
# Local fallback: use the Vite proxy in frontend/vite.config.ts.
VITE_API_BASE_URL=/api

# Vercel/Render deployment example:
# VITE_API_BASE_URL=https://<render-service>.onrender.com/api

# Backward-compatible alias accepted by the code. Leave empty unless needed.
VITE_API_URL=

# ---- Frontend auth ----
# Keep false for demo/fallback mode. When true, Supabase URL and publishable key
# must also be configured.
VITE_AUTH_ENABLED=false
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Backward-compatible alias accepted by the code.
VITE_SUPABASE_ANON_KEY=
