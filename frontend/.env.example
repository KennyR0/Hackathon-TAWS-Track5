# Public frontend configuration. Do not place backend secrets here.
VITE_API_BASE_URL=https://<render-service>/api
VITE_AUTH_ENABLED=false
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_key

# Local development can keep using the Vite proxy:
# VITE_API_BASE_URL=/api
