{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.8.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:types": "openapi-typescript ../contracts/openapi.json -o src/shared/api/generated/openapi.ts",
